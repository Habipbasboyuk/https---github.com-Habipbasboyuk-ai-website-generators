msgstr "Tetapkan bahasa pembina."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1451,
#: ../build/bricks/includes/elements/slider-nested.php:109,
#: ../includes/admin/admin-screen-settings.php:1451,
