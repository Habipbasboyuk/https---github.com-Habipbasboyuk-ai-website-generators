msgstr "Selang Autosave (saat)"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1373,
#: ../includes/admin/admin-screen-settings.php:1373
msgid "Default: 60 seconds. Minimum autosave interval is 15 seconds."
msgstr "Lalai: 60 saat. Selang autosave minimum adalah 15 saat."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1383,
#: ../build/bricks/includes/admin/admin-screen-settings.php:1396,
#: ../includes/admin/admin-screen-settings.php:1383,
#: ../includes/admin/admin-screen-settings.php:1396
msgid "Builder mode"
msgstr "Mod pembina"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1399,
#: ../includes/admin/admin-screen-settings.php:1399
msgid "Create your own builder mode via CSS variables."
msgstr "Cipta mod pembina anda sendiri melalui pembolehubah CSS."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1443,
#: ../includes/admin/admin-screen-settings.php:1443
