msgstr "Chuyển hướng đến trang xác thực tùy chỉnh"

#: ../build/bricks/includes/admin/admin-screen-settings.php:807,
#: ../build/bricks/includes/admin/admin-screen-system-information.php:67,
#: ../includes/admin/admin-screen-settings.php:807,
