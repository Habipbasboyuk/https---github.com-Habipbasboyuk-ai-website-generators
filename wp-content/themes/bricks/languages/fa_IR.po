msgstr "چگونه کلید مخفی API Google reCAPTCHA v3 خود را دریافت کنید"

#: ../build/bricks/includes/admin/admin-screen-settings.php:2326,
#: ../includes/admin/admin-screen-settings.php:2339
msgid "How to get your hCaptcha site key"
msgstr "چگونه کلید سایت hCaptcha خود را دریافت کنید"

#: ../build/bricks/includes/admin/admin-screen-settings.php:2334,
