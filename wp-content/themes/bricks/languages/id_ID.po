msgstr "Perluas elemen aktif & gulir ke tampilan"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1646,
#: ../includes/admin/admin-screen-settings.php:1646
msgid "Wrap element"
msgstr "Bungkus elemen"

