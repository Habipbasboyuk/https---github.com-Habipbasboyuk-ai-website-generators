#: ../includes/elements/nav-nested.php:868
msgid "Never"
msgstr "Tidak pernah"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1793,
#: ../includes/admin/admin-screen-settings.php:1793
msgid ""
"Control when to show the global classes import manager when pasting "
"elements, importing classes or templates."
msgstr ""
"Kontrol kapan menampilkan manajer impor kelas global saat menempel elemen, "
"mengimpor kelas atau template."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1798,
#: ../includes/admin/admin-screen-settings.php:1798
msgid "Render"
msgstr "Render"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1801,
#: ../includes/admin/admin-screen-settings.php:1801
msgid "Disable WP REST API render"
msgstr "Nonaktifkan render WP REST API"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1804,
#: ../includes/admin/admin-screen-settings.php:1804
msgid "Use AJAX instead of WP REST API calls to render elements."
msgstr "Gunakan AJAX alih-alih panggilan WP REST API untuk merender elemen."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1805,
#: ../includes/admin/admin-screen-settings.php:1805
msgid ""
"Only set if you experience problems with the default rendering in the "
"builder (REST API disabled, etc.)"
msgstr ""
"Hanya atur jika Anda mengalami masalah dengan rendering default di pembangun "
"(REST API dinonaktifkan, dll.)"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1817,
#: ../build/bricks/includes/admin/admin-screen-settings.php:1821,
#: ../includes/admin/admin-screen-settings.php:1830,
#: ../includes/admin/admin-screen-settings.php:1834
