msgstr "Skrip body ditambahkan tepat setelah membuka tag %s."

#: ../build/bricks/includes/admin/admin-screen-settings.php:2947,
#: ../build/bricks/includes/settings/settings-page.php:550,
#: ../includes/admin/admin-screen-settings.php:2960,
#: ../includes/settings/settings-page.php:550
