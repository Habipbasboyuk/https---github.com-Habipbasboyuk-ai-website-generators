#: ../build/bricks/includes/admin/admin-screen-settings.php:1772,
#: ../includes/admin/admin-screen-settings.php:1772
msgid "Global data sync"
msgstr "Sinkronisasi data global"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1776,
#: ../includes/admin/admin-screen-settings.php:1776
msgid "Sync global classes"
msgstr "Sinkronkan kelas global"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1777,
#: ../includes/admin/admin-screen-settings.php:1777
msgid ""
"Enable to sync global classes on every builder save between all open builder "
"instances. Useful to avoid overwriting each others changes when multiple "
"people work on the same dataset (e.g. adding, deleting, modifying global "
"classes)."
msgstr ""
"Aktifkan untuk menyinkronkan kelas global pada setiap penyimpanan pembangun "
"antara semua instance pembangun yang terbuka. Berguna untuk menghindari "
"saling menimpa perubahan ketika beberapa orang bekerja pada dataset yang "
"sama (mis. menambah, menghapus, memodifikasi kelas global)."

#: ../build/bricks/includes/admin/admin-screen-settings.php:1783,
#: ../includes/admin/admin-screen-settings.php:1783
msgid "Global class import manager"
msgstr "Pengelola impor kelas global"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1788,
#: ../includes/admin/admin-screen-settings.php:1788
msgid "Show for class conflicts"
msgstr "Tampilkan untuk konflik kelas"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1789,
#: ../includes/admin/admin-screen-settings.php:1789
msgid "Show for new classes"
msgstr "Tampilkan untuk kelas baru"

#: ../build/bricks/includes/admin/admin-screen-settings.php:1790,
#: ../includes/admin/admin-screen-settings.php:1790
msgid "Show for new & conflicting classes"
msgstr "Tampilkan untuk kelas baru & yang berkonflik"

